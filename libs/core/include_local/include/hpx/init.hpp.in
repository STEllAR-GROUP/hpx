///////////////////////////////////////////////////////////////////////////////
// When HPX_WITH_DISTRIBUTED_RUNTIME is disabled, this generated header
// provides hpx::init, hpx::finalize, and hpx::stop as thin forwarding
// wrappers around their hpx::local counterparts, enabling the "Magic Main"
// (hpx_main.hpp) to work transparently in local-only builds.
///////////////////////////////////////////////////////////////////////////////
namespace hpx {

    // hpx::init_params is an alias for the local-only variant
    using init_params = hpx::local::init_params;

    inline int init(std::function<int(hpx::program_options::variables_map&)> f,
        int argc, char** argv, init_params const& params = init_params())
    {
        return hpx::local::init(HPX_MOVE(f), argc, argv, params);
    }

    inline int init(std::function<int(int, char**)> f, int argc, char** argv,
        init_params const& params = init_params())
    {
        return hpx::local::init(HPX_MOVE(f), argc, argv, params);
    }

    inline int init(std::function<int()> f, int argc, char** argv,
        init_params const& params = init_params())
    {
        return hpx::local::init(HPX_MOVE(f), argc, argv, params);
    }

    inline int init(std::nullptr_t, int argc, char** argv,
        init_params const& params = init_params())
    {
        return hpx::local::init(nullptr, argc, argv, params);
    }

    inline int init(init_params const& params = init_params())
    {
        return hpx::local::init(nullptr, hpx::local::detail::dummy_argc,
            hpx::local::detail::dummy_argv, params);
    }

    inline bool start(
        std::function<int(hpx::program_options::variables_map&)> f, int argc,
        char** argv, init_params const& params = init_params())
    {
        return hpx::local::start(HPX_MOVE(f), argc, argv, params);
    }

    inline bool start(std::function<int(int, char**)> f, int argc, char** argv,
        init_params const& params = init_params())
    {
        return hpx::local::start(HPX_MOVE(f), argc, argv, params);
    }

    inline bool start(std::function<int()> f, int argc, char** argv,
        init_params const& params = init_params())
    {
        return hpx::local::start(HPX_MOVE(f), argc, argv, params);
    }

    inline bool start(std::nullptr_t, int argc, char** argv,
        init_params const& params = init_params())
    {
        return hpx::local::start(nullptr, argc, argv, params);
    }

    inline bool start(
        int argc, char** argv, init_params const& params = init_params())
    {
        return hpx::local::start(nullptr, argc, argv, params);
    }

    inline bool start(init_params const& params = init_params())
    {
        return hpx::local::start(nullptr, hpx::local::detail::dummy_argc,
            hpx::local::detail::dummy_argv, params);
    }

    inline int finalize(hpx::error_code& ec = throws)
    {
        return hpx::local::finalize(ec);
    }

    inline int stop(hpx::error_code& ec = throws)
    {
        return hpx::local::stop(ec);
    }
}    // namespace hpx
