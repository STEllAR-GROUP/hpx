// Do not edit this file! It has been generated by the CMake configuration step.

#pragma once

#include <hpx/config/defines.hpp>

// The compilation will fall back to using the HPX headers (instead of the
// generated C++ module interface files) if any of the following is true:
//
// - C++ modules are not enabled
// - Otherwise:
//   - The HPX @libname@ library is being compiled
//   - The module interface file is being compiled
//   - The current translation unit is not forcing to disable using C++ modules
//
#if !defined(HPX_COMPILE_WITH_MODULES) ||                                      \
    defined(HPX_ @libname_upper @_EXPORTS) ||                                  \
    (defined(HPX_COMPILE_BMI) &&                                               \
        (defined(HPX_COMPILE_CORE_WITH_MODULES) ||                             \
            defined(HPX_COMPILE_FULL_WITH_MODULES))) ||                        \
    defined(HPX_HAVE_FORCE_NO_CXX_MODULES)
@module_headers @
#else

// Include all standard library headers before importing module to prevent ODR
// violations.
#include <hpx/config/std_headers.hpp>
@module_macro_headers @

// Import either HPX.Core (local runtime) or HPX.Core.Full (distributed
// runtime), whichever is appropriate for this translation unit.
#if defined(HPX_HAVE_MODULE_INIT_RUNTIME) ||                                   \
    defined(HPX_HAVE_MODULE_RUNTIME_DISTRIBUTED)
    import HPX.Core.Full;
#else
    import HPX.Core;
#endif

#endif
